# ── Local dev AI (direct browser call, dev only) ──────────────────────────────
# Get one at https://console.anthropic.com
# Leave blank in production — the server key below handles it via /api/ai
VITE_ANTHROPIC_API_KEY=

# ── Supabase (client-safe — anon key is meant to be public) ───────────────────
# Project URL and anon key from https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Server-side keys (Vercel env vars — never sent to browser) ────────────────
# Set these in Vercel dashboard → Project → Settings → Environment Variables
ANTHROPIC_API_KEY=sk-ant-...
